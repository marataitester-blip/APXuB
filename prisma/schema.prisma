generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Project {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  name         String
  description  String?
  appUrl       String?
  repoUrl      String?
  techPassport String?
  updatedAt    DateTime @updatedAt
}
