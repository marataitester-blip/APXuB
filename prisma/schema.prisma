generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
}

model Project {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  name         String
  description  String?
  appUrl       String?
  repoUrl      String?
  techPassport String?
  fileTree     Json?    // <--- НОВОЕ ПОЛЕ: Кладовка для Дворецкого
  updatedAt    DateTime @updatedAt
}
